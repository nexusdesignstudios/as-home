              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/forgot-password?email={{email}}",
              "host": ["{{base_url}}"],
              "path": ["api", "forgot-password"],
              "query": [
                {
                  "key": "email",
                  "value": "{{email}}"
                }
              ]
            },
            "description": "Request a password reset link"
          },
          "response": []
        },
        {
          "name": "Logout",
