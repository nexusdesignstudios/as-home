            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "email",
                  "value": "test@example.com",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "password123",
                  "type": "text"
                },
                {
                  "key": "type",
                  "value": "3",
                  "description": "0: Google, 1: Facebook, 2: Apple, 3: Email/Password",
                  "type": "text"
                },
                {
                  "key": "fcm_id",
                  "value": "",
                  "type": "text"
                }
              ]
            },
            "url": {
