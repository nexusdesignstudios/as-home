    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get OTP",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/get-otp?email=test@example.com",
              "host": ["{{base_url}}"],
              "path": ["api", "get-otp"],
              "query": [
                {
                  "key": "email",
                  "value": "test@example.com",
                  "description": "Required if number is not provided"
                }
              ]
            },
            "description": "Request an OTP via email or phone number. You can provide either email or number."
          },
          "response": []
        },
        {
          "name": "Get OTP (Mobile)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/get-otp?number=1234567890",
              "host": ["{{base_url}}"],
              "path": ["api", "get-otp"],
              "query": [
                {
                  "key": "number",
                  "value": "1234567890",
                  "description": "Required if email is not provided"
                }
              ]
            },
            "description": "Request an OTP via phone number. This uses Twilio to send SMS."
          },
          "response": []
        },
        {
          "name": "Verify OTP (Email)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = JSON.parse(responseBody);",
                  "if (jsonData.error === false) {",
                  "    pm.environment.set(\"auth_id\", jsonData.auth_id);",
                  "    console.log(\"Auth ID saved to environment variables\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/verify-otp?email=test@example.com&otp=123456",
              "host": ["{{base_url}}"],
              "path": ["api", "verify-otp"],
              "query": [
                {
                  "key": "email",
                  "value": "test@example.com",
                  "description": "Required if number is not provided"
                },
                {
                  "key": "otp",
                  "value": "123456",
                  "description": "The OTP received via email or SMS"
                }
              ]
            },
            "description": "Verify the OTP sent to email. On successful verification, it returns an auth_id that can be used for registration."
          },
          "response": []
        },
        {
          "name": "Verify OTP (Mobile)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = JSON.parse(responseBody);",
                  "if (jsonData.error === false) {",
                  "    pm.environment.set(\"auth_id\", jsonData.auth_id);",
                  "    console.log(\"Auth ID saved to environment variables\");",
